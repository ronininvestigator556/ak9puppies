---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/puppies", label: "Puppies" },
  { href: "/parents", label: "Parents" },
  { href: "/training", label: "Training" },
  { href: "/gallery", label: "Gallery" },
  { href: "/apply", label: "Apply" },
  { href: "/contact", label: "Contact" },
];
---

<header class="border-b border-[#B08D57]/20 bg-[#0D0D0D]">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
    <a href="/" class="font-serif text-xl tracking-wide text-[#F2F2F2]">
      Alliance K9
    </a>
    <nav aria-label="Primary navigation">
      <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-[#A3A3A3]">
        {
          navItems.map((item) => (
            <li>
              <a class="transition hover:text-[#B08D57]" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
