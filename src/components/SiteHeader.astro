---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/puppies", label: "Puppies" },
  { href: "/parents", label: "Parents" },
  { href: "/training", label: "Training" },
  { href: "/gallery", label: "Gallery" },
  { href: "/apply", label: "Apply" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-gold/20 bg-midnight/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
    <a href="/" class="font-heading text-xl tracking-wide text-ivory">
      Alliance K9
    </a>
    <nav aria-label="Primary navigation">
      <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-stone">
        {
          navItems.map((item) => (
            <li>
              <a class="transition hover:text-gold" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
