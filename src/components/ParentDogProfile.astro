---
import type { CollectionEntry } from "astro:content";
import ImageWithOverlay from "./ImageWithOverlay.astro";
import TraitChip from "./TraitChip.astro";

interface Props {
  dog: CollectionEntry<"dogs">;
  traits?: string[];
  imageReady?: boolean;
}

const { dog, traits = [], imageReady = false } = Astro.props;
---

<article class="luxury-card grid gap-6 p-5 lg:grid-cols-[0.85fr_1fr]">
  <ImageWithOverlay
    src={imageReady ? dog.data.heroImage : undefined}
    alt={`${dog.data.name}, ${dog.data.role} for Alliance K9`}
  />
  <div class="flex flex-col justify-center">
    <p class="text-sm uppercase tracking-[0.18em] text-gold">{dog.data.role}</p>
    <h3 class="mt-2 font-heading text-3xl text-ivory">{dog.data.name}</h3>
    <p class="mt-1 text-sm text-stone">{dog.data.breed}</p>
    {dog.data.registryNotes && <p class="mt-3 text-sm text-stone">{dog.data.registryNotes}</p>}
    <p class="mt-5 text-sm leading-6 text-stone">{dog.data.temperamentSummary}</p>
    <p class="mt-4 text-sm leading-6 text-stone">{dog.data.workingNotes}</p>
    {
      traits.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {traits.map((trait) => <TraitChip label={trait} />)}
        </div>
      )
    }
  </div>
</article>
