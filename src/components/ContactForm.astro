---
interface Props {
  formName?: string;
  netlify?: boolean;
}

const { formName = "contact-inquiry", netlify = false } = Astro.props;
---

<form
  class="luxury-card grid gap-5 p-6"
  name={formName}
  method="post"
  action="/thank-you"
  data-netlify={netlify ? "true" : undefined}
  netlify-honeypot={netlify ? "bot-field" : undefined}
>
  <input type="hidden" name="form-name" value={formName} />
  <p class="hidden">
    <label>
      Do not fill this out if you are human:
      <input name="bot-field" />
    </label>
  </p>
  <label class="grid gap-2 text-sm text-stone">
    Full Name
    <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="name" autocomplete="name" required />
  </label>
  <label class="grid gap-2 text-sm text-stone">
    Email Address
    <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="email" type="email" autocomplete="email" required />
  </label>
  <label class="grid gap-2 text-sm text-stone">
    Phone Number
    <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="phone" autocomplete="tel" required />
  </label>
  <label class="grid gap-2 text-sm text-stone">
    Inquiry Type
    <select class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="inquiryType" required>
      <option value="">Select one</option>
      <option>Puppy Placement</option>
      <option>Training</option>
      <option>Working / Protection Dog</option>
      <option>Future Litter</option>
      <option>General Question</option>
    </select>
    <span class="text-xs leading-5 text-stone">Choose the option that best fits your question. If you are unsure, select General Question.</span>
  </label>
  <div class="grid gap-5 sm:grid-cols-2">
    <label class="grid gap-2 text-sm text-stone">
      Preferred Puppy
      <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="preferredPuppy" />
      <span class="text-xs leading-5 text-stone">If you are asking about a specific puppy, include the puppy's name here.</span>
    </label>
    <label class="grid gap-2 text-sm text-stone">
      Dog Name
      <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="dogName" />
    </label>
    <label class="grid gap-2 text-sm text-stone">
      Dog Breed
      <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="dogBreed" />
    </label>
    <label class="grid gap-2 text-sm text-stone">
      Dog Age
      <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="dogAge" />
    </label>
    <label class="grid gap-2 text-sm text-stone">
      Location
      <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="location" />
    </label>
    <label class="grid gap-2 text-sm text-stone">
      Preferred Contact Method
      <select class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="preferredContactMethod">
        <option>No preference</option>
        <option>Email</option>
        <option>Phone</option>
        <option>Text</option>
      </select>
    </label>
  </div>
  <p class="text-xs leading-5 text-stone">
    For training inquiries, include your dog's breed, age, behavior concerns, and training goals in the message.
  </p>
  <label class="grid gap-2 text-sm text-stone">
    Message
    <textarea class="min-h-36 rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="message" required></textarea>
    <span class="text-xs leading-5 text-stone">Helpful details include your goals, experience level, household environment, timeline, and any specific questions.</span>
  </label>
  <button class="inline-flex min-h-11 w-fit items-center justify-center rounded-md bg-gold px-5 py-2.5 text-sm font-semibold text-midnight transition hover:bg-ivory" type="submit">
    Send Message
  </button>
</form>
