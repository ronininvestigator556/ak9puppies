---
const footerLinks = [
  { href: "/puppies", label: "Puppies" },
  { href: "/parents", label: "Parents" },
  { href: "/training", label: "Training" },
  { href: "/apply", label: "Apply" },
  { href: "/contact", label: "Contact" },
];
---

<footer class="border-t border-gold/20 bg-[#111]">
  <div class="mx-auto grid max-w-6xl gap-6 px-6 py-8 sm:grid-cols-[1fr_auto] sm:items-start">
    <div>
      <p class="font-heading text-lg text-ivory">Alliance K9</p>
      <p class="mt-2 max-w-xl text-sm leading-6 text-stone">
        Working-Bred. Family-Raised. Purpose-Matched.
      </p>
    </div>
    <nav aria-label="Footer navigation">
      <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-stone sm:justify-end">
        {
          footerLinks.map((item) => (
            <li>
              <a class="transition hover:text-gold" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>
