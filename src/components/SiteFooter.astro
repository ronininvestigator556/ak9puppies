---
const footerLinks = [
  { href: "/puppies", label: "Puppies" },
  { href: "/parents", label: "Parents" },
  { href: "/training", label: "Training" },
  { href: "/apply", label: "Apply" },
  { href: "/contact", label: "Contact" },
];
---

<footer class="border-t border-[#B08D57]/20 bg-[#111]">
  <div class="mx-auto grid max-w-6xl gap-6 px-6 py-8 sm:grid-cols-[1fr_auto] sm:items-start">
    <div>
      <p class="font-serif text-lg text-[#F2F2F2]">Alliance K9</p>
      <p class="mt-2 max-w-xl text-sm leading-6 text-[#A3A3A3]">
        Working-Bred. Family-Raised. Purpose-Matched.
      </p>
    </div>
    <nav aria-label="Footer navigation">
      <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-[#A3A3A3] sm:justify-end">
        {
          footerLinks.map((item) => (
            <li>
              <a class="transition hover:text-[#B08D57]" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>
