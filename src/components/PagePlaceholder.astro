---
import CTAButton from "./CTAButton.astro";
import Section from "./Section.astro";
import StatusBadge from "./StatusBadge.astro";
import TraitChip from "./TraitChip.astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<Section eyebrow={eyebrow} title={title} description={description}>
  <div class="luxury-card luxury-card-hover mt-10 max-w-3xl p-6">
    <div class="flex flex-wrap items-center gap-3">
      <StatusBadge status="Evaluation Hold" />
      <TraitChip label="Phase 2 system" />
      <TraitChip label="Reusable components" />
    </div>
    <p class="mt-5 text-sm leading-6 text-stone">
      Placeholder content remains intentionally light. This page is now using the shared design tokens,
      card treatment, badges, trait chips, and CTA variants that will support the full MVP build.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <CTAButton href="/puppies">View Puppies</CTAButton>
      <CTAButton href="/apply" variant="secondary">Apply / Inquire</CTAButton>
    </div>
  </div>
</Section>
