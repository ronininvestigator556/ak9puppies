---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="mx-auto max-w-6xl px-6 py-20">
  <p class="text-sm uppercase tracking-[0.2em] text-[#B08D57]">{eyebrow}</p>
  <h1 class="mt-4 max-w-3xl font-serif text-4xl leading-tight text-[#F2F2F2] sm:text-5xl">
    {title}
  </h1>
  <p class="mt-5 max-w-2xl text-lg leading-8 text-[#A3A3A3]">
    {description}
  </p>
  <div class="mt-10 rounded-lg border border-[#B08D57]/20 bg-[#1B1B1B] p-6 text-sm leading-6 text-[#A3A3A3]">
    Phase 1 placeholder. Full page content and visual design will be added in later MVP phases.
  </div>
</section>
