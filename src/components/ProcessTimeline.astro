---
interface TimelineItem {
  title: string;
  description: string;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<ol class="grid gap-4">
  {
    items.map((item, index) => (
      <li class="luxury-card grid gap-4 p-5 sm:grid-cols-[auto_1fr]">
        <div class="flex h-10 w-10 items-center justify-center rounded-full border border-gold/50 bg-gold/10 text-sm font-semibold text-gold">
          {index + 1}
        </div>
        <div>
          <h3 class="font-heading text-xl text-ivory">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-stone">{item.description}</p>
        </div>
      </li>
    ))
  }
</ol>
