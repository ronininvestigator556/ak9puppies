---
interface Props {
  formName?: string;
  netlify?: boolean;
}

const { formName = "training-inquiry", netlify = false } = Astro.props;
---

<form
  class="luxury-card grid gap-6 p-6"
  name={formName}
  method="post"
  action="/thank-you"
  data-netlify={netlify ? "true" : undefined}
  netlify-honeypot={netlify ? "bot-field" : undefined}
>
  <input type="hidden" name="form-name" value={formName} />
  <p class="hidden">
    <label>
      Do not fill this out if you are human:
      <input name="bot-field" />
    </label>
  </p>

  <fieldset class="grid gap-4">
    <legend class="font-heading text-2xl text-ivory">Your Details</legend>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="grid gap-2 text-sm text-stone">
        Name
        <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="name" autocomplete="name" required />
      </label>
      <label class="grid gap-2 text-sm text-stone">
        Email
        <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="email" type="email" autocomplete="email" required />
      </label>
      <label class="grid gap-2 text-sm text-stone">
        Phone
        <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="phone" autocomplete="tel" required />
      </label>
      <label class="grid gap-2 text-sm text-stone">
        Preferred service
        <select class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="preferredService" required>
          <option value="">Select one</option>
          <option>Foundation Obedience</option>
          <option>Puppy Foundations</option>
          <option>Working Dog Development</option>
          <option>Unsure / need guidance</option>
        </select>
      </label>
    </div>
  </fieldset>

  <fieldset class="grid gap-4">
    <legend class="font-heading text-2xl text-ivory">Dog and Goals</legend>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="grid gap-2 text-sm text-stone">
        Dog name
        <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="dogName" />
      </label>
      <label class="grid gap-2 text-sm text-stone">
        Dog age
        <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="dogAge" />
      </label>
      <label class="grid gap-2 text-sm text-stone">
        Breed
        <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="breed" />
      </label>
      <label class="grid gap-2 text-sm text-stone">
        Timeline
        <input class="rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="timeline" />
      </label>
    </div>
    <label class="grid gap-2 text-sm text-stone">
      Training goals
      <textarea class="min-h-32 rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="trainingGoals" required></textarea>
    </label>
    <label class="grid gap-2 text-sm text-stone">
      Behavior concerns
      <textarea class="min-h-28 rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="behaviorConcerns"></textarea>
    </label>
    <label class="grid gap-2 text-sm text-stone">
      Additional notes
      <textarea class="min-h-28 rounded-md border border-gold/20 bg-midnight px-4 py-3 text-ivory" name="additionalNotes"></textarea>
    </label>
  </fieldset>

  <button class="inline-flex min-h-11 w-fit items-center justify-center rounded-md bg-gold px-5 py-2.5 text-sm font-semibold text-midnight transition hover:bg-ivory" type="submit">
    Submit Training Inquiry
  </button>
</form>
