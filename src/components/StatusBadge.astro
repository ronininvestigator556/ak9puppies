---
interface Props {
  status: "Available" | "Pending" | "Reserved" | "Sold" | "Evaluation Hold";
}

const { status } = Astro.props;

const tone = {
  Available: "border-gold/55 bg-gold/15 text-ivory",
  Pending: "border-stone/40 bg-stone/10 text-stone",
  Reserved: "border-gold/35 bg-gold/10 text-gold",
  Sold: "border-stone/30 bg-stone/10 text-stone",
  "Evaluation Hold": "border-ivory/30 bg-ivory/10 text-ivory",
};
---

<span
  class:list={[
    "inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em]",
    tone[status],
  ]}
>
  {status}
</span>
