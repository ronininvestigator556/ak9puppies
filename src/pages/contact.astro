---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import CTAButton from "../components/CTAButton.astro";
import Section from "../components/Section.astro";
---

<BaseLayout
  title="Contact | Alliance K9"
  description="Contact Alliance K9 about puppies, training, or future availability."
>
  <Section
    eyebrow="Contact"
    title="Contact Alliance K9"
    description="Have questions about a puppy, training, or future availability? Send a message and we will help point you in the right direction."
  >
    <div class="mt-10 grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="grid gap-5">
        <div class="luxury-card p-6">
          <h2 class="font-heading text-2xl text-ivory">Puppy Inquiries</h2>
          <p class="mt-3 text-sm leading-6 text-stone">
            For current Ranger x Mila puppy interest, the application gives the clearest picture of fit.
          </p>
          <div class="mt-5">
            <CTAButton href="/apply" variant="secondary">Start Application</CTAButton>
          </div>
        </div>

        <div class="luxury-card p-6">
          <h2 class="font-heading text-2xl text-ivory">Training Inquiries</h2>
          <p class="mt-3 text-sm leading-6 text-stone">
            Share your dog, goals, and current challenges so Alliance K9 can recommend an appropriate next step.
          </p>
          <div class="mt-5">
            <CTAButton href="/training" variant="secondary">View Training</CTAButton>
          </div>
        </div>

        <div class="luxury-card p-6">
          <h2 class="font-heading text-2xl text-ivory">Response Expectation</h2>
          <p class="mt-3 text-sm leading-6 text-stone">
            Messages are reviewed directly. Include your goals, location, and timeline to make the first response more useful.
          </p>
        </div>
      </div>

      <ContactForm netlify />
    </div>
  </Section>
</BaseLayout>
