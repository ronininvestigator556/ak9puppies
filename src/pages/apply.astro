---
import BaseLayout from "../layouts/BaseLayout.astro";
import ApplicationForm from "../components/ApplicationForm.astro";
import CTAButton from "../components/CTAButton.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import ProcessTimeline from "../components/ProcessTimeline.astro";
import Section from "../components/Section.astro";

const processItems = [
  {
    title: "Submit an Application",
    description: "Tell us about your experience, goals, home environment, and what kind of puppy you are looking for.",
  },
  {
    title: "Placement Conversation",
    description: "We review your application and discuss which puppies may align with your needs, expectations, and handling experience.",
  },
  {
    title: "Deposit & Reservation",
    description: "A deposit confirms serious interest and may secure placement order or a selected puppy depending on availability and fit.",
  },
  {
    title: "Puppy Matching",
    description: "Puppy selection is guided by temperament observations, drive level, confidence, affection, and long-term suitability.",
  },
  {
    title: "Pickup or Transport",
    description: "Once placement is confirmed, we coordinate pickup, travel, or available transport options.",
  },
  {
    title: "Ongoing Support",
    description: "Alliance K9 remains available for guidance as your puppy transitions into the home and begins the next stage of development.",
  },
];

const faqItems = [
  {
    question: "Do I need working-dog experience?",
    answer: "Working-breed experience is helpful, especially for higher-drive puppies, but it is not the only factor. Placement depends on goals, lifestyle, expectations, willingness to train, and which puppy may be the right fit.",
  },
  {
    question: "Does applying guarantee a puppy?",
    answer: "No. The application begins the placement conversation. Alliance K9 may recommend a specific puppy, suggest a different match, or advise waiting depending on fit and availability.",
  },
  {
    question: "How does the deposit work?",
    answer: "A $500 deposit confirms serious interest and may secure placement order or a selected puppy once fit and availability are discussed.",
  },
  {
    question: "Can I choose based on looks?",
    answer: "Appearance matters, but temperament and fit matter more. We encourage buyers to consider each puppy's personality, drive level, affection, confidence, and recommended placement.",
  },
  {
    question: "Do you offer training support?",
    answer: "Yes. Alliance K9 offers training support and guidance for puppy foundations, obedience, behavior, and working-dog development.",
  },
];
---

<BaseLayout
  title="Apply for a Puppy | Alliance K9 Dogs"
  description="Start the Alliance K9 puppy application for the current Ranger x Mila litter. Apply for purpose-bred Dutch Shepherd and Belgian Malinois puppies placed by temperament, drive, and long-term fit."
  image="/assets/processed/homepage/mila-puppy-hero.webp"
  imageAlt="Mila with one of the Ranger x Mila puppies."
>
  <Section
    eyebrow="Puppy Application"
    title="Start the Placement Conversation"
    description="Every Alliance K9 puppy is placed with long-term fit in mind. This application helps us understand your experience, goals, lifestyle, and what kind of dog you are hoping to bring home."
  >
    <div class="mt-8 flex flex-wrap gap-3">
      <CTAButton href="#puppy-application">Begin Application</CTAButton>
      <CTAButton href="/puppies/" variant="secondary">View Available Puppies</CTAButton>
    </div>
  </Section>

  <Section
    eyebrow="Placement"
    title="The Right Match Matters"
    description="Working-line Dutch Shepherd and Belgian Malinois puppies are not one-size-fits-all dogs. Each puppy in the Ranger x Mila litter is being observed for temperament, confidence, affection, drive, engagement, and the ability to settle so we can better understand where each pup is most likely to thrive."
    class="pt-0"
  >
    <p class="mt-5 max-w-3xl text-sm leading-6 text-stone">
      The application process helps us compare your goals and home environment with what we are seeing in the puppies. Some pups may be better suited for experienced working homes, protection development, or sport. Others may be a better fit for active families wanting a loyal, trainable companion with strong genetics and support behind them.
    </p>
    <p class="mt-4 max-w-3xl text-sm leading-6 text-stone">
      Our goal is not simply to place puppies quickly. Our goal is to help create successful long-term matches.
    </p>
  </Section>

  <Section eyebrow="Process" title="How the Placement Process Works" class="pt-0">
    <div class="mt-8">
      <ProcessTimeline items={processItems} />
    </div>
  </Section>

  <Section
    eyebrow="Reservation"
    title="Deposit & Reservation"
    description="A $500 deposit is required to reserve a puppy or hold placement position. Deposits help confirm serious interest and allow us to plan placement conversations, pickup timing, and buyer support more effectively."
    class="pt-0"
  >
    <p class="mt-5 max-w-3xl text-sm leading-6 text-stone">
      Because puppy placement is based on fit, a deposit should not be viewed as an automatic purchase button. Alliance K9 reserves the right to guide placement based on the puppy's temperament, the buyer's goals, and the long-term suitability of the match.
    </p>
  </Section>

  <Section
    id="puppy-application"
    eyebrow="Application Form"
    title="Puppy Application"
    description="Please complete the application below as thoroughly as possible. Honest answers help us better understand your goals and guide the placement process."
    class="scroll-mt-28 pt-0"
  >
    <div class="mt-10 max-w-5xl">
      <ApplicationForm netlify />
    </div>
  </Section>

  <Section eyebrow="Questions" title="Application Questions" class="pt-0">
    <div class="mt-8">
      <FAQAccordion items={faqItems} />
    </div>
  </Section>

  <Section class="pt-0">
    <div class="luxury-card grid gap-6 p-8 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="eyebrow">Next Step</p>
        <h2 class="mt-3 font-heading text-3xl text-ivory">Ready to Begin?</h2>
        <p class="mt-4 max-w-2xl text-sm leading-6 text-stone">
          If you are serious about bringing home a Ranger x Mila puppy, the application is the best next step. Tell us what you are looking for, and we will help guide the conversation from there.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <CTAButton href="#puppy-application">Submit Application</CTAButton>
        <CTAButton href="/puppies/" variant="secondary">View Available Puppies</CTAButton>
      </div>
    </div>
  </Section>
</BaseLayout>
