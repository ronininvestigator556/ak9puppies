---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
import Lightbox from "../components/Lightbox.astro";
import Section from "../components/Section.astro";
import { firstHeroImage, listPublicImages, publicAsset } from "../lib/assets";

const galleryItems = await getCollection("gallery");
const categories = ["puppies", "parents", "training", "group"];
const manualGalleryImages = listPublicImages("/assets/processed/gallery");
const galleryImage =
  firstHeroImage("/assets/processed/gallery") ??
  manualGalleryImages[0];
const configuredGalleryItems = galleryItems
  .map((item) => ({
    src: publicAsset(item.data.src),
    alt: item.data.alt,
  }))
  .filter((item): item is { src: string; alt: string } => Boolean(item.src));
const lightboxItems = [
  ...manualGalleryImages.map((image) => ({
    src: image,
    alt: "Alliance K9 gallery photo.",
  })),
  ...configuredGalleryItems.map((item) => ({
    src: item.src,
    alt: item.alt,
  })),
];
---

<BaseLayout
  title="Gallery | Alliance K9"
  description="Alliance K9 puppy, parent, training, and litter media gallery."
  image={galleryImage}
>
  <Section
    eyebrow="Gallery"
    title="Alliance K9 Media"
    description="A portrait-friendly gallery structure is ready for puppy, parent, training, and group images once processed web assets are added."
  >
    <div class="mt-8 flex flex-wrap gap-2">
      {categories.map((category) => <span class="rounded-full border border-gold/20 px-3 py-1 text-xs uppercase tracking-[0.16em] text-stone">{category}</span>)}
    </div>

    <div class="mt-10">
      {lightboxItems.length > 0 && <Lightbox items={lightboxItems} />}
      {
        lightboxItems.length === 0 && (
          <div class="luxury-card p-6 text-sm leading-6 text-stone">
            Gallery images are ready to be added without changing this page structure.
          </div>
        )
      }
    </div>

    <div class="mt-10">
      <CTAButton href="/contact" variant="secondary">Ask About Availability</CTAButton>
    </div>
  </Section>
</BaseLayout>
