---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
import ImageWithOverlay from "../components/ImageWithOverlay.astro";
import Section from "../components/Section.astro";

const galleryItems = await getCollection("gallery");
const categories = ["puppies", "parents", "training", "group"];
---

<BaseLayout
  title="Gallery | Alliance K9"
  description="Alliance K9 puppy, parent, training, and litter media gallery."
>
  <Section
    eyebrow="Gallery"
    title="Alliance K9 Media"
    description="A portrait-friendly gallery structure is ready for puppy, parent, training, and group images once processed web assets are added."
  >
    <div class="mt-8 flex flex-wrap gap-2">
      {categories.map((category) => <span class="rounded-full border border-gold/20 px-3 py-1 text-xs uppercase tracking-[0.16em] text-stone">{category}</span>)}
    </div>

    <div class="mt-10 columns-1 gap-5 sm:columns-2 lg:columns-3">
      {
        galleryItems.map((item) => (
          <div class="mb-5 break-inside-avoid">
            <ImageWithOverlay alt={item.data.alt} aspect={item.data.category === "group" ? "aspect-[4/3]" : "aspect-[4/5]"} />
            <p class="mt-3 text-xs uppercase tracking-[0.16em] text-gold">{item.data.category}</p>
          </div>
        ))
      }
      {
        galleryItems.length === 0 && (
          <div class="luxury-card p-6 text-sm leading-6 text-stone">
            Processed gallery images can be added in Phase 8 without changing this page structure.
          </div>
        )
      }
    </div>

    <div class="mt-10">
      <CTAButton href="/contact" variant="secondary">Ask About Availability</CTAButton>
    </div>
  </Section>
</BaseLayout>
