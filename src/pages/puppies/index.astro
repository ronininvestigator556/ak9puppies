---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAButton from "../../components/CTAButton.astro";
import PuppyCard from "../../components/PuppyCard.astro";
import Section from "../../components/Section.astro";
import { sortPuppies } from "../../lib/puppies";

const puppies = sortPuppies(await getCollection("puppies"));
const availableCount = puppies.filter((puppy) => puppy.data.status === "Available").length;
const reservedCount = puppies.filter((puppy) => puppy.data.status === "Reserved").length;
---

<BaseLayout
  title="Available Puppies | Alliance K9"
  description="View the current Ranger x Mila litter, including available and reserved puppies."
>
  <Section
    eyebrow="Current Litter"
    title="Ranger x Mila Puppies"
    description="Each puppy is being individually observed and evaluated to help match temperament, drive, and personality to the right home."
  >
    <div class="mt-8 grid gap-4 rounded-lg border border-gold/20 bg-graphite/60 p-5 text-sm text-stone sm:grid-cols-3">
      <p><span class="font-semibold text-ivory">Born:</span> March 21, 2026</p>
      <p><span class="font-semibold text-ivory">Available:</span> {availableCount} puppies</p>
      <p><span class="font-semibold text-ivory">Reserved:</span> {reservedCount} puppies</p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {puppies.map((puppy) => <PuppyCard puppy={puppy} />)}
    </div>

    <div class="mt-10">
      <CTAButton href="/apply">Apply / Inquire</CTAButton>
    </div>
  </Section>
</BaseLayout>
