---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAButton from "../../components/CTAButton.astro";
import ImageWithOverlay from "../../components/ImageWithOverlay.astro";
import ProfileStats from "../../components/ProfileStats.astro";
import Section from "../../components/Section.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import TraitChip from "../../components/TraitChip.astro";
import { listPuppyImages, publicAsset } from "../../lib/assets";
import { getSimilarPuppies, sortPuppies } from "../../lib/puppies";

export async function getStaticPaths() {
  const puppies = await getCollection("puppies");

  return puppies.map((puppy) => ({
    params: { slug: puppy.data.slug },
    props: { puppy, puppies },
  }));
}

const { puppy, puppies } = Astro.props;
const { Content } = await render(puppy);
const similarPuppies = getSimilarPuppies(puppy, sortPuppies(puppies));
const heroImage = publicAsset(puppy.data.heroImage);
const galleryImages = listPuppyImages(puppy.data.slug).filter((image) => image !== heroImage);
---

<BaseLayout
  title={`${puppy.data.name} | Alliance K9 Puppies`}
  description={puppy.data.shortDescription}
>
  <Section
    eyebrow="Puppy Profile"
    title={puppy.data.name}
    description={puppy.data.shortDescription}
  >
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <StatusBadge status={puppy.data.status} />
      {puppy.data.traits.map((trait) => <TraitChip label={trait} />)}
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
      <ProfileStats
        stats={[
          { label: "Status", value: puppy.data.statusLabel ?? puppy.data.status },
          { label: "Sex", value: puppy.data.sex },
          { label: "Collar", value: puppy.data.collar },
          { label: "Birthdate", value: "March 21, 2026" },
          { label: "Weight Notes", value: puppy.data.weightNotes },
        ]}
      />

      <div class="luxury-card p-6">
        <ImageWithOverlay
          src={heroImage}
          alt={`${puppy.data.name}, ${puppy.data.collar}-collar ${puppy.data.sex.toLowerCase()} puppy.`}
          aspect="aspect-[4/3]"
          class="mb-6"
        />
        <h2 class="font-heading text-2xl text-ivory">Placement Notes</h2>
        <div class="prose prose-invert mt-5 max-w-none text-stone">
          <Content />
        </div>
        <p class="mt-5 text-sm leading-6 text-stone">{puppy.data.fullDescription}</p>

        <div class="mt-6">
          <h3 class="font-heading text-xl text-ivory">Best Fit</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {puppy.data.bestFit.map((fit) => <TraitChip label={fit} />)}
          </div>
        </div>

        <div class="mt-6">
          <h3 class="font-heading text-xl text-ivory">Development Checklist</h3>
          <ul class="mt-3 grid gap-2 text-sm text-stone sm:grid-cols-2">
            {puppy.data.developmentChecklist.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>

    {
      similarPuppies.length > 0 && (
        <div class="mt-10">
          <h2 class="font-heading text-2xl text-ivory">Similar Puppies</h2>
          <div class="mt-4 flex flex-wrap gap-3">
            {similarPuppies.map((similar) => (
              <CTAButton href={`/puppies/${similar.data.slug}`} variant="secondary">
                {similar.data.name}
              </CTAButton>
            ))}
          </div>
        </div>
      )
    }

    {
      galleryImages.length > 0 && (
        <div class="mt-10">
          <h2 class="font-heading text-2xl text-ivory">Puppy Gallery</h2>
          <div class="mt-5 columns-1 gap-5 sm:columns-2 lg:columns-3">
            {galleryImages.map((image) => (
              <ImageWithOverlay
                src={image}
                alt={`${puppy.data.name} gallery photo.`}
                aspect="aspect-[4/5]"
                class="mb-5 break-inside-avoid"
              />
            ))}
          </div>
        </div>
      )
    }

    <div class="mt-10 flex flex-wrap gap-3">
      <CTAButton href="/apply">Apply / Inquire</CTAButton>
      <CTAButton href="/parents" variant="secondary">Meet Ranger x Mila</CTAButton>
    </div>
  </Section>
</BaseLayout>
